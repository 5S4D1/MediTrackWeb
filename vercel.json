{
  "rewrites": [
    {
      "source": "/((?!robots.txt|favicon.ico|.*\\.(png|jpg|svg|css|js)).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "all"
        }
      ]
    }
  ]
}